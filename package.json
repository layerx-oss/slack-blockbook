{
  "name": "@layerx/slack-blockbook",
  "version": "0.0.3",
  "description": "Storybook-like preview tool for Slack Block Kit development",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/layerx-oss/slack-blockbook.git"
  },
  "homepage": "https://github.com/layerx-oss/slack-blockbook#readme",
  "bugs": {
    "url": "https://github.com/layerx-oss/slack-blockbook/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "author": "LayerX Inc.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "slack-blockbook": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "slack",
    "block-kit",
    "preview",
    "storybook",
    "jsx-slack",
    "development",
    "hot-reload"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "example": "pnpm --dir example dev",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "esbuild": "^0.25.0",
    "jiti": "^2.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/node": "^22.10.1",
    "eslint": "^9.16.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.17.0",
    "vitest": "^4.0.15"
  },
  "packageManager": "pnpm@9.15.1+sha256.9e534e70afef06374f6126b44bda5760947135ce16a30aef1010e965fb7e3e3e"
}
